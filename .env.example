# Copy to .env for local `netlify dev` — never commit .env.
# Set these in Netlify dashboard → Site Settings → Environment Variables for production.
# CONTACT_SENDER_EMAIL is the BARE address; the function wraps it as: Milionová Investice <noreply@notifications.milionovainvestice.cz>
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
CONTACT_SENDER_EMAIL=noreply@notifications.milionovainvestice.cz
